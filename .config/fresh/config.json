{
  "version": 2,
  "theme": "better-terminal.json",
  "languages": {
    "qml": {
      "extensions": [
        "qml"
      ],
      "grammar": "QML",
      "auto_indent": true,
      "show_whitespace_tabs": true,
      "format_on_save": false
    }
  },
  "lsp": {
    "qml": {
      "command": "/usr/lib/qt6/bin/qmlls",
      "enabled": true,
      "auto_start": true,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      }
    }
  },
  "editor": {
    "cursor_style": "blinking_bar"
  }
}