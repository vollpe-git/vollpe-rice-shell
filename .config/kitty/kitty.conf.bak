font_family      family=NType82Mono-Regular
#Monocraft
#"JetBrainsMonoNL Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto

background_opacity 0.3
window_padding_width 6
allow_remote_control yes
enable_audio_bell no
url_style curly
url_color #A565F4


map ctrl+up        scroll_line_up
map ctrl+down      scroll_line_down
map ctrl+u 	      scroll_page_up
map ctrl+d 	      scroll_page_down
map ctrl+home      scroll_home
map ctrl+end       scroll_end

#colors (foreground = text color)
foreground #ffffff
background #663263
selection_foreground #000000
selection_background #f2a7bc
#00b3ff

cursor #ffffff
cursor_text_color #000000

# url underline color when hovering with mouse
url_color #f2a7bc

# Colors for marks (marked text in the terminal) [i dont know what they are so if i see green i know where to go]
mark1_foreground #22ff00
mark1_background #22ff00
mark2_foreground #22ff00
mark2_background #22ff00
mark3_foreground #22ff00
mark3_background #22ff00

# The 16 terminal colors

# black
color0 #1d1d1b
color8 #3c3c3c

# red
color1 #f687a7
color9 #f2a7bc

# green
color2  #15ff00
color10 #a2ff96

# yellow
color3  #ffd900
color11 #fff475

# blue
color4  #0095ff
color12 #00b3ff

# magenta
color5  #643bac
color13 #965ebd

# cyan
color6  #43c7ff
color14 #00ffff

# white
color7  #debad5
color15 #ffffff